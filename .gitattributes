# Auto-detect text files, ensure LF in the repo
*       text=auto

# Kotlin / Java / Gradle — always LF
*.kt    text eol=lf
*.java  text eol=lf
*.kts   text eol=lf
*.xml   text eol=lf
*.gradle text eol=lf
*.properties text eol=lf

# Gradle wrapper shell script — must stay LF (runs on macOS/Linux)
gradlew text eol=lf

# Windows batch — must stay CRLF
*.bat   text eol=crlf

# Binary
*.png   binary
*.jpg   binary
*.apk   binary
*.jar   binary
